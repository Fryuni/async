{
  "name": "@nanostores/async",
  "version": "0.1.0",
  "description": "Async computed stores for Nano Stores",
  "keywords": [
    "nanostores",
    "stores",
    "state",
    "state manager",
    "async"
  ],
  "repository": "nanostores/async",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "types": "./index.d.ts",
  "scripts": {
    "test": "pnpm run /^test:/",
    "test:coverage": "pnpm bnt --coverage",
    "test:lint": "prettier -c .",
    "test:size": "size-limit",
    "test:types": "check-dts"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@sinonjs/fake-timers": "^15.1.1",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^25.3.5",
    "@types/sinonjs__fake-timers": "^15.0.1",
    "better-node-test": "^0.8.3",
    "check-dts": "^0.9.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "nanostores": "^1"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "authors": "Luiz Ferraz <luiz@lferraz.com>",
  "clean-publish": {
    "cleanDocs": true
  },
  "size-limit": [
    {
      "name": "Everything",
      "import": {
        "./index.js": "*"
      },
      "limit": "418 B"
    }
  ]
}
